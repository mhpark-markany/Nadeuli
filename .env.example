# 에어코리아 (data.go.kr)
AIRKOREA_API_KEY=your_airkorea_api_key

# 기상청 (data.go.kr)
KMA_API_KEY=your_kma_api_key

# 한국관광공사 TourAPI 4.0 (data.go.kr)
TOUR_API_KEY=your_tour_api_key

# Redis
REDIS_URL=redis://localhost:6379

# Gemini (Phase 3)
GEMINI_API_KEY=your_gemini_api_key

# 서버
PORT=3000

# CORS (프론트엔드 URL)
CORS_ORIGIN=*

# Kakao REST API Key
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Kakao OAuth
KAKAO_CLIENT_SECRET=your_kakao_client_secret

# JWT
JWT_SECRET=your_jwt_secret_generate_with_openssl_rand_base64_32

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:xxx@postgres.railway.internal:5432/railway
DATABASE_PUBLIC_URL=postgresql://postgres:xxx@xxx.railway.app:xxxxx/railway